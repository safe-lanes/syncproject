modules = ["dotnet-7.0", "dotnet-8.0", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SyncConsole"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MariaDB"

[[workflows.workflow]]
name = "SyncConsole"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash SyncConsole/scripts/run-sync.sh"

[[workflows.workflow]]
name = "MariaDB"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash SyncConsole/scripts/start-mysql.sh"

[workflows.workflow.metadata]
outputType = "console"
